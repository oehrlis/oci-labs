# .env.example - mfa_oma_setup stack
# Copy to .env and fill in your OCIDs.
# .env is git-ignored - never commit it.
# Source before terraform commands: source .env

# Retrieve from 1Password:
#   op read "op://oradba-labs/OCI Tenancy/tenancy_ocid"
export TF_VAR_tenancy_ocid="ocid1.tenancy.oc1..xxx"

# Compartment for Email Delivery resources and SMTP policy
export TF_VAR_compartment_ocid="ocid1.compartment.oc1..xxx"

# Identity Domain OCID: Identity & Security -> Domains -> <Domain> -> OCID
export TF_VAR_identity_domain_ocid="ocid1.domain.oc1..xxx"
